APP_ENV=development
HTTP_PORT=8080
LOG_LEVEL=info

DB_HOST=localhost
DB_PORT=5432
DB_USER=sage
DB_PASSWORD=sage
DB_NAME=sage
DB_SSLMODE=disable

# 32+ random characters
JWT_SECRET=change-me-to-a-long-random-string-32+chars
# minutes
JWT_ACCESS_TTL_MIN=15
# hours
JWT_REFRESH_TTL_HOUR=168

# exactly 32 bytes
ENCRYPTION_KEY=01234567890123456789012345678901

# comma-separated host allowlist for provider SSRF protection
ALLOWED_PROVIDER_HOSTS=api.openai.com,openrouter.ai,api.groq.com,api.deepseek.com,localhost

RATE_LIMIT_PER_MIN=60

# initial admin user (used by `go run ./cmd/seed`)
SEED_ADMIN_EMAIL=admin@sage.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Administrator
