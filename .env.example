APP_ENV=production

DB_USER=sage
DB_PASSWORD=sage
DB_NAME=sage

# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-32-or-more-characters
# Generate with: openssl rand -base64 32 (must decode to 32 bytes)
ENCRYPTION_KEY=01234567890123456789012345678901

ALLOWED_PROVIDER_HOSTS=api.openai.com,openrouter.ai,api.groq.com,api.deepseek.com
RATE_LIMIT_PER_MIN=60
LOG_LEVEL=info

NEXT_PUBLIC_API_URL=http://localhost:8080
